# xhisper configuration
# Copy to ~/.config/xhisper/xhisperrc and customize
# When in doubt, check by running 'xhisper --log'

# Transcription Settings:
long-recording-threshold : 1000
transcription-prompt     : ""

# Paste Timing (seconds):
non-ascii-initial-delay : 0.15 # Increase this if first character comes out wrong.
non-ascii-default-delay : 0.025

# Silence Detection:
silence-threshold  : -50
silence-percentage : 95

# AI Auto-editing:
# Cleans up grammar, removes filler words, fixes punctuation after transcription.
auto-edit        : true

# Tone Adaptation:
# Detects the active window and adjusts auto-edit style (e.g., casual for Slack, formal for email).
tone-adaptation  : true

# Personal Dictionary:
# Add custom words/names to ~/.config/xhisper/dictionary.txt (one per line)
# to improve Whisper's recognition accuracy for domain-specific terms.

# API Endpoints:
# By default, xhisper uses Groq's API (requires GROQ_API_KEY in ~/.env).
# You can point STT and LLM to any OpenAI-compatible endpoint — including local servers.
#
# Speech-to-text (Whisper):
# stt-url     : https://api.groq.com/openai/v1
# stt-api-key :
# stt-model   :
#
# LLM (auto-edit):
# llm-url     : https://api.groq.com/openai/v1
# llm-api-key :
# llm-model   : llama-3.3-70b-versatile
#
# Local Whisper example (whisper.cpp server):
# stt-url     : http://localhost:8080/v1
# stt-api-key :
# stt-model   : whisper-1
#
# Local LLM example (Ollama):
# llm-url     : http://localhost:11434/v1
# llm-api-key :
# llm-model   : llama3

